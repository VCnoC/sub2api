+package service
+
+import (
+	"testing"
+
+	"github.com/tidwall/gjson"
+)
+
+func TestGrokCPACreateRequestAndResponse(t *testing.T) {
+	raw := []byte(`{"model":"grok-imagine-video","prompt":"a cat","seconds":"20","size":"1280x720"}`)
+	body, meta, err := BuildGrokCPAVideoCreateRequest(raw, "grok-imagine-video")
+	if err != nil {
+		t.Fatalf("build request: %v", err)
+	}
+	// seconds 20 应被钳到 15
+	if got := gjson.GetBytes(body, "duration").Int(); got != 15 {
+		t.Fatalf("duration=%d want 15", got)
+	}
+	if got := gjson.GetBytes(body, "aspect_ratio").String(); got != "16:9" {
+		t.Fatalf("aspect_ratio=%s want 16:9", got)
+	}
+	if got := gjson.GetBytes(body, "resolution").String(); got != "720p" {
+		t.Fatalf("resolution=%s want 720p", got)
+	}
+	if meta.Seconds != "15" || meta.Size != "1280x720" {
+		t.Fatalf("meta=%+v", meta)
+	}
+
+	upstream := []byte(`{"request_id":"req-123","status":"pending"}`)
+	out, err := BuildGrokCPAVideosCreateResponse(upstream, meta)
+	if err != nil {
+		t.Fatalf("create response: %v", err)
+	}
+	if got := gjson.GetBytes(out, "object").String(); got != "video" {
+		t.Fatalf("object=%s", got)
+	}
+	if got := gjson.GetBytes(out, "id").String(); got != "req-123" {
+		t.Fatalf("id=%s", got)
+	}
+	if got := gjson.GetBytes(out, "status").String(); got != "queued" {
+		t.Fatalf("status=%s want queued", got)
+	}
+	if got := gjson.GetBytes(out, "model").String(); got != "grok-imagine-video" {
+		t.Fatalf("model=%s", got)
+	}
+	if got := gjson.GetBytes(out, "seconds").String(); got != "15" {
+		t.Fatalf("seconds=%s", got)
+	}
+	if !gjson.GetBytes(out, "created_at").Exists() {
+		t.Fatal("created_at missing")
+	}
+}
+
+func TestGrokCPARetrieveResponse(t *testing.T) {
+	upstream := []byte(`{"request_id":"req-123","status":"done","model":"grok-imagine-video","progress":100,"video":{"url":"https://x.ai/v.mp4","duration":6}}`)
+	out := BuildGrokCPAVideosRetrieveResponse("req-123", upstream, "")
+	if got := gjson.GetBytes(out, "status").String(); got != "completed" {
+		t.Fatalf("status=%s want completed", got)
+	}
+	if got := gjson.GetBytes(out, "video_url").String(); got != "https://x.ai/v.mp4" {
+		t.Fatalf("video_url=%s", got)
+	}
+	if got := gjson.GetBytes(out, "seconds").String(); got != "6" {
+		t.Fatalf("seconds=%s", got)
+	}
+	if got := gjson.GetBytes(out, "object").String(); got != "video" {
+		t.Fatalf("object=%s", got)
+	}
+
+	// failed 场景
+	fail := []byte(`{"request_id":"req-9","status":"error","error":{"message":"boom"}}`)
+	out = BuildGrokCPAVideosRetrieveResponse("req-9", fail, "")
+	if got := gjson.GetBytes(out, "status").String(); got != "failed" {
+		t.Fatalf("status=%s want failed", got)
+	}
+	if got := gjson.GetBytes(out, "error.message").String(); got != "boom" {
+		t.Fatalf("error.message=%s", got)
+	}
+}
+
+func TestGrokCPAUnifiedResponse(t *testing.T) {
+	upstream := []byte(`{"status":"done","video":{"url":"https://x.ai/v.mp4","duration":6},"progress":100}`)
+	out := BuildGrokCPAVideosUnifiedResponse("req-1", upstream)
+	if got := gjson.GetBytes(out, "status").String(); got != "completed" {
+		t.Fatalf("status=%s want completed", got)
+	}
+	if got := gjson.GetBytes(out, "video_url").String(); got != "https://x.ai/v.mp4" {
+		t.Fatalf("video_url=%s", got)
+	}
+	if !gjson.GetBytes(out, "status_update_time").Exists() {
+		t.Fatal("status_update_time missing")
+	}
+
+	// 无 url 时 video_url 应为 null
+	out = BuildGrokCPAVideosUnifiedResponse("req-2", []byte(`{"status":"processing"}`))
+	if got := gjson.GetBytes(out, "video_url"); got.Exists() && got.Type.String() != "Null" {
+		t.Fatalf("video_url should be null, got %s", got.Raw)
+	}
+	if got := gjson.GetBytes(out, "status").String(); got != "processing" {
+		t.Fatalf("status=%s", got)
+	}
+}
+
+func TestGrokCPAModelValidation(t *testing.T) {
+	for _, m := range []string{"grok-imagine-video", "xai/grok-imagine-video", "grok/grok-imagine-video-1.5-preview"} {
+		if !IsGrokCPAVideosModel(m) {
+			t.Fatalf("model %s should be supported", m)
+		}
+	}
+	for _, m := range []string{"grok-4", "openai/grok-imagine-video"} {
+		if IsGrokCPAVideosModel(m) {
+			t.Fatalf("model %s should be rejected", m)
+		}
+	}
+	if got := CanonicalGrokCPAVideosModel("xai/grok-imagine-video-1.5-preview"); got != "grok-imagine-video-1.5-preview" {
+		t.Fatalf("canonical=%s", got)
+	}
+}
+
+func TestGrokCPASizeValidation(t *testing.T) {
+	if _, _, _, err := grokCPAVideosSizeOptions("999x999"); err == nil {
+		t.Fatal("invalid size should error")
+	}
+	s, ar, res, err := grokCPAVideosSizeOptions("1080p")
+	if err != nil || s != "720x1280" || ar != "9:16" || res != "720p" {
+		t.Fatalf("1080p mapping: %s %s %s %v", s, ar, res, err)
+	}

diff --git a/backend/internal/service/grok_media_cpa.go b/backend/internal/service/grok_media_cpa.go
new file mode 100644
index 000000000..8af214f7f
--- /dev/null
+++ b/backend/internal/service/grok_media_cpa.go
@@ -0,0 +1,619 @@
+package service
+
+// CPA (cli-proxy-api) 兼容的 Grok 视频接口格式层。
+// 目标：让 sub2api 的 Grok 视频返回与 CPA-2 (64.32.23.242:8318) 完全一致：
+//   - POST /v1/videos、POST /v1/video/create  → OpenAI Sora 风格创建，返回包装后的 video 对象
+//   - GET  /v1/videos/:video_id               → 包装后的查询对象（status 归一 + video_url）
+//   - GET  /v1/video/query?id=                → deepwl 统一查询 schema
+//   - POST /v1/videos/generations|edits|extensions 保持原生透传（与 CPA 一致）
+
+import (
+	"fmt"
+	"net/http"
+	"strconv"
+	"strings"
+	"time"
+
+	"github.com/gin-gonic/gin"
+	"github.com/tidwall/gjson"
+	"github.com/tidwall/sjson"
+)
+
+const (
+	GrokCPADefaultVideosModel      = "grok-imagine-video"
+	grokCPAVideos15PreviewModel    = "grok-imagine-video-1.5-preview"
+	grokCPADefaultVideosSeconds    = "4"
+	grokCPADefaultVideosSize       = "720x1280"
+	grokCPADefaultVideosResolution = "720p"
+	grokCPAMaxVideoReferences      = 7
+)
+
+type grokMediaCPAFormat string
+
+const (
+	grokMediaCPAFormatOff      grokMediaCPAFormat = ""
+	grokMediaCPAFormatCreate   grokMediaCPAFormat = "create"
+	grokMediaCPAFormatRetrieve grokMediaCPAFormat = "retrieve"
+	grokMediaCPAFormatUnified  grokMediaCPAFormat = "unified"
+)
+
+const (
+	grokMediaCPAFormatContextKey = "grok_media_cpa_format"
+	grokMediaCPAVideoIDKey       = "grok_media_cpa_video_id"
+	grokMediaCPACreateMetaKey    = "grok_media_cpa_create_meta"
+)
+
+// GrokCPAVideoCreateMeta 记录创建请求元数据，用于把上游响应重塑为 CPA 创建格式。
+type GrokCPAVideoCreateMeta struct {
+	Model     string
+	Prompt    string
+	Seconds   string
+	Size      string
+	CreatedAt int64
+}
+
+// SetGrokMediaCPAResponseFormat 在当前请求上下文上启用 CPA 响应包装。
+func SetGrokMediaCPAResponseFormat(c *gin.Context, format string, videoID string, meta *GrokCPAVideoCreateMeta) {
+	if c == nil {
+		return
+	}
+	c.Set(grokMediaCPAFormatContextKey, format)
+	if strings.TrimSpace(videoID) != "" {
+		c.Set(grokMediaCPAVideoIDKey, strings.TrimSpace(videoID))
+	}
+	if meta != nil {
+		c.Set(grokMediaCPACreateMetaKey, *meta)
+	}
+}
+
+func grokMediaCPAFormatFromContext(c *gin.Context) grokMediaCPAFormat {
+	if c == nil {
+		return grokMediaCPAFormatOff
+	}
+	value, ok := c.Get(grokMediaCPAFormatContextKey)
+	if !ok {
+		return grokMediaCPAFormatOff
+	}
+	format, _ := value.(string)
+	return grokMediaCPAFormat(format)
+}
+
+func grokMediaCPAVideoIDFromContext(c *gin.Context) string {
+	if c == nil {
+		return ""
+	}
+	value, ok := c.Get(grokMediaCPAVideoIDKey)
+	if !ok {
+		return ""
+	}
+	videoID, _ := value.(string)
+	return strings.TrimSpace(videoID)
+}
+
+func grokMediaCPACreateMetaFromContext(c *gin.Context) GrokCPAVideoCreateMeta {
+	if c == nil {
+		return GrokCPAVideoCreateMeta{}
+	}
+	value, ok := c.Get(grokMediaCPACreateMetaKey)
+	if !ok {
+		return GrokCPAVideoCreateMeta{}
+	}
+	meta, _ := value.(GrokCPAVideoCreateMeta)
+	return meta
+}
+
+// applyGrokMediaCPAResponse 按上下文标记把上游 xAI 响应重塑为 CPA 格式；
+// 未标记时原样返回（保持原生透传）。
+func applyGrokMediaCPAResponse(c *gin.Context, respBody []byte) ([]byte, int) {
+	format := grokMediaCPAFormatFromContext(c)
+	if format == grokMediaCPAFormatOff {
+		return respBody, 0
+	}
+	statusOverride := 0
+	var out []byte
+	switch format {
+	case grokMediaCPAFormatCreate:
+		meta := grokMediaCPACreateMetaFromContext(c)
+		transformed, err := BuildGrokCPAVideosCreateResponse(respBody, meta)
+		if err != nil {
+			return respBody, 0
+		}
+		out = transformed
+	case grokMediaCPAFormatRetrieve:
+		videoID := grokMediaCPAVideoIDFromContext(c)
+		out = BuildGrokCPAVideosRetrieveResponse(videoID, respBody, GrokCPADefaultVideosModel)
+	case grokMediaCPAFormatUnified:
+		videoID := grokMediaCPAVideoIDFromContext(c)
+		out = BuildGrokCPAVideosUnifiedResponse(videoID, respBody)
+	default:
+		return respBody, 0
+	}
+	// 与 CPA 一致：成功响应固定 200（上游可能是 202）；终态 failed 时查询接口返回 502。
+	statusOverride = http.StatusOK
+	if format != grokMediaCPAFormatCreate && gjson.GetBytes(out, "status").String() == "failed" {
+		statusOverride = http.StatusBadGateway
+	}
+	return out, statusOverride
+}
+
+// ===== 模型校验（对齐 CPA isXAIVideosModel / canonicalXAIVideosModel） =====
+
+func grokCPAVideosModelBase(model string) string {
+	model = strings.TrimSpace(model)
+	if idx := strings.LastIndex(model, "/"); idx >= 0 {
+		model = model[idx+1:]
+	}
+	return strings.ToLower(strings.TrimSpace(model))
+}
+
+func grokCPAVideosModelPrefix(model string) string {
+	model = strings.TrimSpace(model)
+	if idx := strings.LastIndex(model, "/"); idx >= 0 {
+		return strings.ToLower(strings.TrimSpace(model[:idx]))
+	}
+	return ""
+}
+
+// IsGrokCPAVideosModel 判定模型是否为 CPA 支持的视频模型。
+func IsGrokCPAVideosModel(model string) bool {
+	base := grokCPAVideosModelBase(model)
+	if base != GrokCPADefaultVideosModel && base != grokCPAVideos15PreviewModel {
+		return false
+	}
+	switch grokCPAVideosModelPrefix(model) {
+	case "", "xai", "x-ai", "grok":
+		return true
+	}
+	return false
+}
+
+// CanonicalGrokCPAVideosModel 归一视频模型名（去掉前缀）。
+func CanonicalGrokCPAVideosModel(model string) string {
+	switch grokCPAVideosModelBase(model) {
+	case grokCPAVideos15PreviewModel:
+		return grokCPAVideos15PreviewModel
+	default:
+		return GrokCPADefaultVideosModel
+	}
+}
+
+// ===== 创建请求转换（对齐 CPA buildXAIVideosCreateRequest） =====
+
+// BuildGrokCPAVideoCreateRequest 把 OpenAI Sora 风格创建请求转换为 xAI 原生请求体。
+func BuildGrokCPAVideoCreateRequest(rawJSON []byte, model string) ([]byte, GrokCPAVideoCreateMeta, error) {
+	prompt := strings.TrimSpace(gjson.GetBytes(rawJSON, "prompt").String())
+	if prompt == "" {
+		return nil, GrokCPAVideoCreateMeta{}, fmt.Errorf("prompt is required")
+	}
+
+	// 兼容 seconds（OpenAI 风格）和 duration（xAI 原生风格），seconds 优先。
+	secondsRaw := gjson.GetBytes(rawJSON, "seconds").String()
+	if strings.TrimSpace(secondsRaw) == "" {
+		secondsRaw = gjson.GetBytes(rawJSON, "duration").String()
+	}
+	seconds, duration, err := grokCPANormalizeVideosSeconds(secondsRaw)
+	if err != nil {
+		return nil, GrokCPAVideoCreateMeta{}, err
+	}
+
+	size, aspectRatio, resolution, err := grokCPAVideosSizeOptions(gjson.GetBytes(rawJSON, "size").String())
+	if err != nil {
+		return nil, GrokCPAVideoCreateMeta{}, err
+	}
+	if value := grokCPAVideosAspectRatio(gjson.GetBytes(rawJSON, "aspect_ratio").String(), ""); value != "" {
+		aspectRatio = value
+	}
+	if value := grokCPAVideosResolution(gjson.GetBytes(rawJSON, "resolution").String(), ""); value != "" {
+		resolution = value
+	}
+
+	imageURL, err := grokCPAVideosInputImageURL(rawJSON)
+	if err != nil {
+		return nil, GrokCPAVideoCreateMeta{}, err
+	}
+	referenceImages := grokCPACollectVideoReferenceImages(rawJSON)
+	if len(referenceImages) == 1 && imageURL == "" {
+		imageURL = referenceImages[0]
+		referenceImages = nil
+	}
+	if len(referenceImages) > grokCPAMaxVideoReferences {
+		return nil, GrokCPAVideoCreateMeta{}, fmt.Errorf("reference_images supports at most %d images on xAI", grokCPAMaxVideoReferences)
+	}
+	if imageURL != "" && len(referenceImages) > 0 {
+		return nil, GrokCPAVideoCreateMeta{}, fmt.Errorf("image and reference_images cannot be combined on xAI")
+	}
+	if len(referenceImages) > 0 && duration > 10 {
+		duration = 10
+		seconds = "10"
+	}
+
+	videoModel := CanonicalGrokCPAVideosModel(model)
+	req := []byte(`{}`)
+	req, _ = sjson.SetBytes(req, "model", videoModel)
+	req, _ = sjson.SetBytes(req, "prompt", prompt)
+	req, _ = sjson.SetRawBytes(req, "duration", []byte(strconv.FormatInt(duration, 10)))
+	req, _ = sjson.SetBytes(req, "aspect_ratio", aspectRatio)
+	req, _ = sjson.SetBytes(req, "resolution", resolution)
+	if imageURL != "" {
+		req, _ = sjson.SetBytes(req, "image.url", imageURL)
+	}
+	for _, image := range referenceImages {
+		req, _ = sjson.SetBytes(req, "reference_images.-1.url", image)
+	}
+
+	meta := GrokCPAVideoCreateMeta{
+		Model:     videoModel,
+		Prompt:    prompt,
+		Seconds:   seconds,
+		Size:      size,
+		CreatedAt: time.Now().Unix(),
+	}
+	return req, meta, nil
+}
+
+func grokCPANormalizeVideosSeconds(raw string) (string, int64, error) {
+	seconds := strings.TrimSpace(raw)
+	if seconds == "" {
+		seconds = grokCPADefaultVideosSeconds
+	}
+	duration, err := strconv.ParseInt(seconds, 10, 64)
+	if err != nil {
+		return "", 0, fmt.Errorf("seconds must be an integer")
+	}
+	if duration < 1 {
+		duration = 1
+	}
+	if duration > 15 {
+		duration = 15
+	}
+	return strconv.FormatInt(duration, 10), duration, nil
+}
+
+func grokCPAVideosSizeOptions(raw string) (size string, aspectRatio string, resolution string, err error) {
+	size = strings.TrimSpace(raw)
+	if size == "" {
+		size = grokCPADefaultVideosSize
+	}
+	switch strings.ToLower(size) {
+	case "720x1280", "1024x1792":
+		return size, "9:16", grokCPADefaultVideosResolution, nil
+	case "1280x720", "1792x1024":
+		return size, "16:9", grokCPADefaultVideosResolution, nil
+	case "480p":
+		return grokCPADefaultVideosSize, "9:16", "480p", nil
+	case "720p":
+		return grokCPADefaultVideosSize, "9:16", "720p", nil
+	case "1080p":
+		return grokCPADefaultVideosSize, "9:16", "720p", nil
+	default:
+		return "", "", "", fmt.Errorf("size must be one of 720x1280, 1280x720, 1024x1792, 1792x1024, 480p, 720p, or 1080p")
+	}
+}
+
+func grokCPAVideosAspectRatio(raw string, fallback string) string {
+	switch strings.ToLower(strings.TrimSpace(raw)) {
+	case "1:1", "square":
+		return "1:1"
+	case "16:9", "landscape":
+		return "16:9"
+	case "9:16", "portrait":
+		return "9:16"
+	case "4:3":
+		return "4:3"
+	case "3:4":
+		return "3:4"
+	case "3:2":
+		return "3:2"
+	case "2:3":
+		return "2:3"
+	default:
+		return fallback
+	}
+}
+
+func grokCPAVideosResolution(raw string, fallback string) string {
+	switch strings.ToLower(strings.TrimSpace(raw)) {
+	case "480p":
+		return "480p"
+	case "720p":
+		return "720p"
+	default:
+		return fallback
+	}
+}
+
+func grokCPAVideosInputImageURL(rawJSON []byte) (string, error) {
+	inputRef := gjson.GetBytes(rawJSON, "input_reference")
+	if inputRef.Exists() {
+		imageURL := strings.TrimSpace(inputRef.Get("image_url").String())
+		fileID := strings.TrimSpace(inputRef.Get("file_id").String())
+		if imageURL != "" && fileID != "" {
+			return "", fmt.Errorf("input_reference must provide exactly one of image_url or file_id")
+		}
+		if fileID != "" {
+			return "", fmt.Errorf("input_reference.file_id is not supported for xAI video generation; use input_reference.image_url")
+		}
+		if imageURL != "" {
+			return imageURL, nil
+		}
+	}
+
+	image := gjson.GetBytes(rawJSON, "image")
+	if image.Exists() {
+		if image.Type == gjson.String {
+			return strings.TrimSpace(image.String()), nil
+		}
+		if value := strings.TrimSpace(image.Get("url").String()); value != "" {
+			return value, nil
+		}
+		if value := strings.TrimSpace(image.Get("image_url.url").String()); value != "" {
+			return value, nil
+		}
+	}
+
+	return strings.TrimSpace(gjson.GetBytes(rawJSON, "image_url").String()), nil
+}
+
+func grokCPACollectVideoReferenceImages(rawJSON []byte) []string {
+	out := make([]string, 0)
+	appendRef := func(value string) {
+		value = strings.TrimSpace(value)
+		if value != "" {
+			out = append(out, value)
+		}
+	}
+	collectArray := func(result gjson.Result) {
+		if !result.IsArray() {
+			return
+		}
+		result.ForEach(func(_, item gjson.Result) bool {
+			if item.Type == gjson.String {
+				appendRef(item.String())
+				return true
+			}
+			if value := item.Get("url").String(); value != "" {
+				appendRef(value)
+				return true
+			}
+			if value := item.Get("image_url").String(); value != "" {
+				appendRef(value)
+				return true
+			}
+			if value := item.Get("image_url.url").String(); value != "" {
+				appendRef(value)
+			}
+			return true
+		})
+	}
+	collectArray(gjson.GetBytes(rawJSON, "reference_images"))
+	collectArray(gjson.GetBytes(rawJSON, "reference_image_urls"))
+	collectArray(gjson.GetBytes(rawJSON, "images"))
+	collectArray(gjson.GetBytes(rawJSON, "input_reference"))
+	return out
+}
+
+// ===== 响应包装（对齐 CPA buildVideos*APIResponseFromXAI） =====
+
+// BuildGrokCPAVideosCreateResponse 把 xAI 创建响应重塑为 CPA 的 video 对象格式。
+func BuildGrokCPAVideosCreateResponse(payload []byte, meta GrokCPAVideoCreateMeta) ([]byte, error) {
+	requestID := strings.TrimSpace(gjson.GetBytes(payload, "request_id").String())
+	if requestID == "" {
+		requestID = strings.TrimSpace(gjson.GetBytes(payload, "id").String())
+	}
+	if requestID == "" {
+		return nil, fmt.Errorf("xAI video response did not include request_id")
+	}
+
+	out := []byte(`{"object":"video","progress":0,"status":"queued"}`)
+	out, _ = sjson.SetBytes(out, "id", requestID)
+	out, _ = sjson.SetBytes(out, "model", meta.Model)
+	out, _ = sjson.SetBytes(out, "prompt", meta.Prompt)
+	out, _ = sjson.SetBytes(out, "seconds", meta.Seconds)
+	out, _ = sjson.SetBytes(out, "size", meta.Size)
+	out, _ = sjson.SetBytes(out, "created_at", meta.CreatedAt)
+	if status := GrokCPAOpenAIVideoStatus(gjson.GetBytes(payload, "status").String()); status != "" {
+		out, _ = sjson.SetBytes(out, "status", status)
+	}
+	if progress := gjson.GetBytes(payload, "progress"); progress.Exists() {
+		out, _ = sjson.SetRawBytes(out, "progress", []byte(progress.Raw))
+	}
+	return out, nil
+}
+
+// BuildGrokCPAVideosRetrieveResponse 把 xAI 查询响应重塑为 CPA 的查询格式。
+func BuildGrokCPAVideosRetrieveResponse(videoID string, payload []byte, fallbackModel string) []byte {
+	out := []byte(`{"object":"video"}`)
+	out, _ = sjson.SetBytes(out, "id", videoID)
+
+	model := strings.TrimSpace(gjson.GetBytes(payload, "model").String())
+	if model == "" {
+		model = fallbackModel
+	}
+	out, _ = sjson.SetBytes(out, "model", model)
+
+	if status := GrokCPAOpenAIVideoStatus(gjson.GetBytes(payload, "status").String()); status != "" {
+		out, _ = sjson.SetBytes(out, "status", status)
+	}
+	if progress := gjson.GetBytes(payload, "progress"); progress.Exists() {
+		out, _ = sjson.SetRawBytes(out, "progress", []byte(progress.Raw))
+	}
+	if duration := gjson.GetBytes(payload, "video.duration"); duration.Exists() {
+		out, _ = sjson.SetBytes(out, "seconds", duration.String())
+	}
+	if videoURL := gjson.GetBytes(payload, "video.url").String(); videoURL != "" {
+		out, _ = sjson.SetBytes(out, "video_url", videoURL)
+	}
+	if errPayload := gjson.GetBytes(payload, "error"); errPayload.Exists() {
+		if errPayload.IsObject() {
+			out, _ = sjson.SetRawBytes(out, "error", []byte(errPayload.Raw))
+		} else {
+			errMsg := strings.TrimSpace(errPayload.String())
+			out, _ = sjson.SetBytes(out, "error.message", errMsg)
+			out, _ = sjson.SetBytes(out, "error.type", "invalid_request_error")
+			out, _ = sjson.SetRawBytes(out, "error.param", []byte("null"))
+			out, _ = sjson.SetBytes(out, "error.code", "error")
+		}
+	}
+	return out
+}
+
+// BuildGrokCPAVideosUnifiedResponse 把 xAI 查询响应重塑为 deepwl 统一查询 schema。
+func BuildGrokCPAVideosUnifiedResponse(videoID string, payload []byte) []byte {
+	out := []byte(`{}`)
+	out, _ = sjson.SetBytes(out, "id", videoID)
+	out, _ = sjson.SetBytes(out, "status", grokCPAUnifiedVideoStatus(gjson.GetBytes(payload, "status").String()))
+
+	if v := grokCPAFirstNonEmptyVideoString(payload, "video.url", "video_url"); v != "" {
+		out, _ = sjson.SetBytes(out, "video_url", v)
+	} else {
+		out, _ = sjson.SetRawBytes(out, "video_url", []byte("null"))
+	}
+
+	if raw, ok := grokCPAFirstNumberRaw(payload, "status_update_time", "updated_at", "last_update", "last_status_update"); ok {
+		out, _ = sjson.SetRawBytes(out, "status_update_time", []byte(raw))
+	} else {
+		out, _ = sjson.SetBytes(out, "status_update_time", time.Now().Unix())
+	}
+
+	if raw, ok := grokCPAFirstNumberRaw(payload, "progress", "video.progress"); ok {
+		out, _ = sjson.SetRawBytes(out, "progress", []byte(raw))
+	} else {
+		out, _ = sjson.SetBytes(out, "progress", 0)
+	}
+
+	out, _ = sjson.SetBytes(out, "prompt",
+		grokCPAFirstNonEmptyVideoString(payload, "prompt", "video.prompt", "request.prompt"))
+	out, _ = sjson.SetBytes(out, "ratio",
+		grokCPAFirstNonEmptyVideoString(payload, "aspect_ratio", "video.aspect_ratio", "ratio", "video.ratio"))
+	out, _ = sjson.SetBytes(out, "thumbnail_url",
+		grokCPAFirstNonEmptyVideoString(payload, "video.thumbnail_url", "thumbnail_url", "video.preview_url", "preview_url", "video.thumbnail"))
+
+	if errPayload := gjson.GetBytes(payload, "error"); errPayload.Exists() {
+		if errPayload.IsObject() {
+			out, _ = sjson.SetRawBytes(out, "error", []byte(errPayload.Raw))
+		} else {
+			errMsg := strings.TrimSpace(errPayload.String())
+			out, _ = sjson.SetBytes(out, "error.message", errMsg)
+			out, _ = sjson.SetBytes(out, "error.type", "invalid_request_error")
+			out, _ = sjson.SetRawBytes(out, "error.param", []byte("null"))
+			out, _ = sjson.SetBytes(out, "error.code", "error")
+		}
+	}
+
+	return out
+}
+
+// GrokCPAOpenAIVideoStatus 归一上游状态为 OpenAI 视频状态枚举。
+func GrokCPAOpenAIVideoStatus(status string) string {
+	switch strings.ToLower(strings.TrimSpace(status)) {
+	case "queued", "pending":
+		return "queued"
+	case "in_progress", "processing", "running":
+		return "in_progress"
+	case "completed", "done", "succeeded", "success":
+		return "completed"
+	case "failed", "error", "expired", "cancelled", "canceled":
+		return "failed"
+	default:
+		return ""
+	}
+}
+
+// grokCPAUnifiedVideoStatus 归一为 deepwl 规范的四个枚举值。
+func grokCPAUnifiedVideoStatus(status string) string {
+	switch strings.ToLower(strings.TrimSpace(status)) {
+	case "queued", "pending", "in_progress", "processing", "running":
+		return "processing"
+	case "completed", "done", "succeeded", "success":
+		return "completed"
+	case "failed", "error", "expired", "cancelled", "canceled":
+		return "failed"
+	default:
+		return "unknown"
+	}
+}
+
+func grokCPAFirstNonEmptyVideoString(payload []byte, paths ...string) string {
+	for _, p := range paths {
+		if v := strings.TrimSpace(gjson.GetBytes(payload, p).String()); v != "" {
+			return v
+		}
+	}
+	return ""
+}
+
+func grokCPAFirstNumberRaw(payload []byte, paths ...string) (string, bool) {
+	for _, p := range paths {
+		if r := gjson.GetBytes(payload, p); r.Exists() && r.Type == gjson.Number {
+			return r.Raw, true
+		}
+	}
+	return "", false
+}
+
+// ===== 失败响应（对齐 CPA buildVideoFailureResponse / classifyVideoError） =====
+
+// BuildGrokCPAVideoFailureResponse 构造 CPA 风格的视频失败响应（HTTP 502）。
+func BuildGrokCPAVideoFailureResponse(videoID string, raw string) []byte {
+	out := []byte(`{"status":"failed","video_url":null,"progress":0,"prompt":"","ratio":"","thumbnail_url":""}`)
+	if videoID != "" {
+		out, _ = sjson.SetBytes(out, "id", videoID)
+	}
+	out, _ = sjson.SetBytes(out, "status_update_time", time.Now().Unix())
+	code, message := grokCPAClassifyVideoError(raw)
+	out, _ = sjson.SetBytes(out, "error.message", message)
+	out, _ = sjson.SetBytes(out, "error.type", "invalid_request_error")
+	out, _ = sjson.SetRawBytes(out, "error.param", []byte("null"))
+	out, _ = sjson.SetBytes(out, "error.code", code)
+	return out
+}
+
+func grokCPAVideoErrorTextFromRaw(raw string) string {
+	if msg := strings.TrimSpace(gjson.Get(raw, "error.message").String()); msg != "" {
+		return msg
+	}
+	if msg := strings.TrimSpace(gjson.Get(raw, "error.error").String()); msg != "" {
+		return msg
+	}
+	if msg := strings.TrimSpace(gjson.Get(raw, "error").String()); msg != "" {
+		return msg
+	}
+	return strings.TrimSpace(raw)
+}
+
+func grokCPAClassifyVideoError(raw string) (string, string) {
+	switch {
+	case strings.Contains(raw, "content moderation"):
+		return "content_moderation", "视频内容未通过审核，请调整提示词后重试"
+	case strings.Contains(raw, "Failed to read static file"):
+		return "not_found", "视频不存在或已失效"
+	case strings.Contains(raw, "Malformed request ID"):
+		return "invalid_request", "视频ID格式不正确"
+	case strings.Contains(raw, "Prompt length exceeds"):
+		return "invalid_request", "提示词长度超过上限（最多 4096 字符）"
+	case strings.Contains(raw, "Text-to-video is not supported"):
+		return "unsupported_model", "该模型不支持文生视频"
+	case strings.Contains(raw, "is a video model and is therefore not available"):
+		return "unsupported_endpoint", "该视频模型不支持此接口"
+	case strings.Contains(raw, "run out of credits") || strings.Contains(raw, "spending-limit"):
+		return "insufficient_quota", "账号额度已用完"
+	case strings.Contains(raw, "Too many requests") || strings.Contains(raw, "resource-exhausted"):
+		if msg := grokCPAVideoErrorTextFromRaw(raw); msg != "" {
+			return "rate_limited", msg
+		}
+		return "rate_limited", "请求过于频繁，请稍后再试"
+	default:
+		code := strings.TrimSpace(gjson.Get(raw, "code").String())
+		if code == "" {
+			code = "error"
+		}
+		msg := strings.TrimSpace(gjson.Get(raw, "error").String())
+		if msg == "" {
+			msg = raw
+		}
+		if msg == "" {
+			msg = "Upstream request failed"
+		}
+		return code, msg
+	}
+}

@@ -0,0 +1,133 @@
+package handler
+
+// CPA (cli-proxy-api) 兼容的 Grok 视频接口。
+// 接口与返回格式对齐 CPA-2 (64.32.23.242:8318)：
+//   - POST /v1/videos、POST /v1/video/create → OpenAI Sora 风格创建，返回包装 video 对象
+//   - GET  /v1/videos/:request_id            → 包装查询对象（走 GrokVideoStatusCPA）
+//   - GET  /v1/video/query?id=               → deepwl 统一查询 schema
+
+import (
+	"bytes"
+	"io"
+	"net/http"
+	"strings"
+
+	pkghttputil "github.com/Wei-Shaw/sub2api/internal/pkg/httputil"
+	"github.com/Wei-Shaw/sub2api/internal/service"
+	"github.com/gin-gonic/gin"
+	"github.com/tidwall/gjson"
+	"github.com/tidwall/sjson"
+)
+
+// grokCPAVideoError 输出与 CPA writeVideoStringError 一致的错误格式。
+func grokCPAVideoError(c *gin.Context, statusCode int, message string) {
+	out := []byte(`{}`)
+	out, _ = sjson.SetBytes(out, "error.message", message)
+	out, _ = sjson.SetBytes(out, "error.type", "invalid_request_error")
+	out, _ = sjson.SetRawBytes(out, "error.param", []byte("null"))
+	out, _ = sjson.SetBytes(out, "error.code", "invalid_request_error")
+	c.Header("Content-Type", "application/json")
+	c.Status(statusCode)
+	_, _ = c.Writer.Write(out)
+}
+
+// GrokVideoCreateCPA 处理 POST /v1/videos 与 /v1/video/create（OpenAI Sora 风格）。
+// 请求体转换为 xAI 原生格式后复用 grok media 转发链路，响应按 CPA 格式包装。
+func (h *OpenAIGatewayHandler) GrokVideoCreateCPA(c *gin.Context) {
+	rawJSON, err := grokCPAReadVideosCreateRequest(c)
+	if err != nil {
+		grokCPAVideoError(c, http.StatusBadRequest, "Invalid request: "+err.Error())
+		return
+	}
+
+	videoModel := strings.TrimSpace(gjson.GetBytes(rawJSON, "model").String())
+	if videoModel == "" {
+		videoModel = service.GrokCPADefaultVideosModel
+	}
+	if !service.IsGrokCPAVideosModel(videoModel) {
+		grokCPAVideoError(c, http.StatusBadRequest, "Model "+videoModel+" is not supported on /v1/videos. Use "+service.GrokCPADefaultVideosModel+".")
+		return
+	}
+
+	nativeBody, meta, err := service.BuildGrokCPAVideoCreateRequest(rawJSON, videoModel)
+	if err != nil {
+		grokCPAVideoError(c, http.StatusBadRequest, "Invalid request: "+err.Error())
+		return
+	}
+
+	// 用转换后的原生请求体替换入站 body，复用标准 grok media 转发流程。
+	c.Request.Body = io.NopCloser(bytes.NewReader(nativeBody))
+	c.Request.ContentLength = int64(len(nativeBody))
+	c.Request.Header.Set("Content-Type", "application/json")
+
+	service.SetGrokMediaCPAResponseFormat(c, "create", "", &meta)
+	h.handleGrokMedia(c, service.GrokMediaEndpointVideosGenerations, "")
+}
+
+// GrokVideoStatusCPA 处理 GET /v1/videos/:request_id，返回 CPA 包装格式。
+func (h *OpenAIGatewayHandler) GrokVideoStatusCPA(c *gin.Context) {
+	requestID := strings.TrimSpace(c.Param("request_id"))
+	if requestID == "" {
+		grokCPAVideoError(c, http.StatusBadRequest, "Invalid request: video_id is required")
+		return
+	}
+	service.SetGrokMediaCPAResponseFormat(c, "retrieve", requestID, nil)
+	h.handleGrokMedia(c, service.GrokMediaEndpointVideoStatus, requestID)
+}
+
+// GrokVideoQueryCPA 处理 GET /v1/video/query?id=，返回 deepwl 统一查询 schema。
+func (h *OpenAIGatewayHandler) GrokVideoQueryCPA(c *gin.Context) {
+	videoID := strings.TrimSpace(c.Query("id"))
+	if videoID == "" {
+		grokCPAVideoError(c, http.StatusBadRequest, "Invalid request: id is required")
+		return
+	}
+	service.SetGrokMediaCPAResponseFormat(c, "unified", videoID, nil)
+	h.handleGrokMedia(c, service.GrokMediaEndpointVideoStatus, videoID)
+}
+
+// grokCPAReadVideosCreateRequest 读取创建请求：支持 JSON 与表单（对齐 CPA readVideosCreateRequest）。
+func grokCPAReadVideosCreateRequest(c *gin.Context) ([]byte, error) {
+	contentType := strings.ToLower(strings.TrimSpace(c.GetHeader("Content-Type")))
+	if strings.Contains(contentType, "application/json") {
+		body, err := pkghttputil.ReadRequestBodyWithPrealloc(c.Request)
+		if err != nil {
+			return nil, err
+		}
+		if len(bytes.TrimSpace(body)) == 0 {
+			return nil, errRequestBodyEmpty
+		}
+		return body, nil
+	}
+
+	// 表单风格（application/x-www-form-urlencoded / multipart/form-data）
+	if err := c.Request.ParseMultipartForm(32 << 20); err != nil {
+		// ParseMultipartForm 对 urlencoded 表单内部调用 ParseForm，报错即真错。
+		if err = c.Request.ParseForm(); err != nil {
+			return nil, err
+		}
+	}
+	out := []byte(`{}`)
+	setIf := func(key string, keys ...string) {
+		for _, k := range keys {
+			if v := strings.TrimSpace(c.Request.PostFormValue(k)); v != "" {
+				out, _ = sjson.SetBytes(out, key, v)
+				return
+			}
+		}
+	}
+	setIf("model", "model")
+	setIf("prompt", "prompt")
+	setIf("seconds", "seconds", "duration")
+	setIf("size", "size")
+	setIf("aspect_ratio", "aspect_ratio")
+	setIf("resolution", "resolution")
+	setIf("image_url", "image_url", "image")
+	return out, nil
+}
+
+var errRequestBodyEmpty = &grokCPAError{msg: "request body is empty"}
+
+type grokCPAError struct{ msg string }
+
+func (e *grokCPAError) Error() string { return e.msg }
